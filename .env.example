# 📦 Base de Datos (MongoDB Prisma)
# Reemplaza con tu cadena de conexión a MongoDB Atlas
DATABASE_URL="mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/energy-ai?appName=energyAI"

# 🤖 Inteligencia Artificial (Google Gemini / Vercel AI SDK)
# Consigue tu API Key gratuita en: https://aistudio.google.com/
GOOGLE_GENERATIVE_AI_API_KEY="tu_api_key_de_gemini_aqui"

# 🔐 Autenticación (Auth.js)
# Genera un secreto seguro ejecutando en la terminal: npx auth secret
AUTH_SECRET="tu_secreto_generado_aleatoriamente_aqui"

# 🌐 Login con Google (OAuth 2.0)
# Configura tu app en: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID="tu_client_id_aqui.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="tu_client_secret_aqui"